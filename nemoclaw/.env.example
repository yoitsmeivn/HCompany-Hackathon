# Sandbox-side settings for the Kylian WhatsApp ingress agent.
# These live in the NemoClaw sandbox, NOT in the Kylian backend .env.

# Public HTTPS base URL of the Kylian backend (same host as the Twilio tunnel).
KYLIAN_BASE_URL=https://YOUR_KYLIAN_HOST

# Shared secret; MUST equal the backend's NEMOCLAW_INGRESS_TOKEN. Register this
# as an OpenShell provider (runbook step 3) rather than baking it into the image.
NEMOCLAW_INGRESS_TOKEN=change-me

# Comma-separated WhatsApp sender ids allowed to use this sandbox. Keep in sync
# with the backend's WHATSAPP_ALLOWED_IDS. Blank = no restriction (dev only).
WHATSAPP_ALLOWED_IDS=15551230000
