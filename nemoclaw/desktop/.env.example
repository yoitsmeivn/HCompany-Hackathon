# Sandbox-side settings for the Kylian HoloDesktop computer-use sandbox.
# These live in the NemoClaw sandbox, NOT in the Kylian backend .env.

# H Company (Holo) inference — OpenAI-compatible Models API.
HAI_API_KEY=change-me
H_API_BASE_URL=https://api.hcompany.ai/v1
HOLO_MODEL=holo3-1-35b-a3b

# Bearer token the Kylian backend presents on every /tasks call. MUST equal the
# backend's KYLIAN_DESKTOP_SERVICE_TOKEN. Register as an OpenShell provider
# (runbook step 3) rather than baking it into the image.
KYLIAN_DESKTOP_SERVICE_TOKEN=change-me

# Port the holo-desktop service listens on inside the sandbox. NemoClaw publishes
# this over TLS to the backend; the backend uses the published HTTPS endpoint as
# KYLIAN_NEMOCLAW_DESKTOP_URL. The service must bind a sandbox-reachable interface
# (0.0.0.0 inside the sandbox), not just 127.0.0.1.
HOLO_SERVICE_PORT=8792

# Kylian backend host allowed to reach this sandbox (ingress). Keep in sync with
# policies/desktop.yaml. Same host you point KYLIAN_NEMOCLAW_DESKTOP_URL from.
KYLIAN_BACKEND_HOST=YOUR_KYLIAN_HOST

# Virtual display the agent operates (provided by the sandbox desktop channel).
DISPLAY=:99
