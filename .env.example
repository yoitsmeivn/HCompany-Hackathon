KYLIAN_API_PORT=8787
KYLIAN_PUBLIC_BASE_URL=https://YOUR_TUNNEL_HOST
KYLIAN_VOICE_COMPUTER_ID=demo-computer
KYLIAN_EXECUTOR_MODE=mock
KYLIAN_VOICE_PROVIDER=gradium

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# H Company (Holo) integration.
# 1) Brain: when HAI_API_KEY is set, the TEXT channels (WhatsApp/web) run their
#    brain on a Holo model via H's OpenAI-compatible Chat Completions API. Voice
#    stays on the OpenAI Responses path above. Get a key at portal.hcompany.ai.
# 2) Executor: set KYLIAN_EXECUTOR_MODE=h-company to perform REAL desktop
#    actions through the HoloDesktop CLI (`holo`). Install it and run `holo login`
#    on the machine that runs this backend (install.hcompany.ai).
HAI_API_KEY=
H_API_BASE_URL=https://api.hcompany.ai/v1
H_MODEL=holo3-1-35b-a3b
# HoloDesktop CLI binary used by the h-company executor (must be on PATH).
HOLO_CLI_BIN=holo
# Max wall-clock for a single HoloDesktop task, milliseconds.
HOLO_TASK_TIMEOUT_MS=180000

# 3) Executor: set KYLIAN_EXECUTOR_MODE=hai-desktop to perform REAL desktop
#    actions through the local hai-agents[desktop] service (poc/hai-desktop).
#    Start it as a third process next to start:api and dev:web:
#      poc/hai-desktop/.venv/bin/python -m uvicorn desktop_service:app \
#        --app-dir poc/hai-desktop --host 127.0.0.1 --port 8790
# Loopback only — never expose this URL through a tunnel.
KYLIAN_DESKTOP_SERVICE_URL=http://127.0.0.1:8790
# Shared secret between the Kylian backend and the desktop service.
# Generate with: openssl rand -hex 32
KYLIAN_DESKTOP_SERVICE_TOKEN=
# Per-task budget in seconds (10..900); also passed to the H session.
KYLIAN_DESKTOP_TASK_TIMEOUT_S=120

GRADIUM_API_KEY=
GRADIUM_TTS_VOICE=
GRADIUM_STT_MODEL=default
GRADIUM_TTS_MODEL=default

# Gradium TTS voice settings (docs.gradium.ai/guides/voice-settings).
# These shape the GENERATED VOICE only (pacing, variation, similarity).
# They do not change turn-response latency, which is governed by the
# GRADIUM_VAD_* settings, STT finalization, OpenAI response time, and
# TTS connection startup.
# Speed -> json_config.padding_bonus, range -4.0..4.0, negative = faster speech.
GRADIUM_TTS_SPEED=-1.0
# Temperature -> json_config.temp, range 0.0..1.4 (0.0 deterministic).
GRADIUM_TTS_TEMPERATURE=0.5
# Voice similarity -> json_config.cfg_coef, range 1.0..4.0 (very high can distort).
GRADIUM_TTS_VOICE_SIMILARITY=2.0
# Optional rewrite rules language code (e.g. en); blank = omitted.
GRADIUM_TTS_REWRITE_RULES=
# Optional pronunciation dictionary ID (top-level pronunciation_id); blank = omitted.
GRADIUM_TTS_PRONUNCIATION_ID=
GRADIUM_STT_LANGUAGE=en
# End-of-turn detection. Lower values reduce the silence before Kylian answers,
# but overly aggressive values may cut callers off during natural mid-sentence
# pauses. Previous conservative values: 16 / 2 / 0.5 / 3.
GRADIUM_STT_DELAY_IN_FRAMES=8
GRADIUM_VAD_HORIZON_SECONDS=1
GRADIUM_VAD_INACTIVITY_THRESHOLD=0.5
GRADIUM_VAD_CONSECUTIVE_STEPS=2

# NemoClaw / OpenClaw WhatsApp ingress (see nemoclaw/README.md).
# Shared secret the in-sandbox agent presents as `Authorization: Bearer <token>`
# (or `x-nemoclaw-token`). Optional in dev/mock; REQUIRED when NODE_ENV=production.
NEMOCLAW_INGRESS_TOKEN=
# Computer the WhatsApp channel drives. Defaults to KYLIAN_VOICE_COMPUTER_ID.
NEMOCLAW_COMPUTER_ID=
# Comma-separated WhatsApp sender ids allowed to reach the ingress. Blank = no
# restriction (dev only). Keep in sync with the sandbox's WHATSAPP_ALLOWED_IDS.
WHATSAPP_ALLOWED_IDS=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_VALIDATE_SIGNATURES=true
TWILIO_MEDIA_STREAM_URL=wss://YOUR_TUNNEL_HOST/twilio/media-stream

# Optional explicit OpenAI speech fallback only.
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=alloy

# Leave blank in dev so the app uses the Vite proxy (/api -> localhost:8787).
# Only set when the frontend is NOT served by Vite dev.
VITE_KYLIAN_API_BASE_URL=

# Comma-separated browser origins allowed to call the API cross-origin.
# Defaults to http://localhost:5173,http://127.0.0.1:5173
KYLIAN_ALLOWED_ORIGINS=
