{
  "name": "kylian",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,web \"npm:dev:api\" \"npm:dev:web\"",
    "dev:web": "vite",
    "dev:api": "node --watch --env-file-if-exists=.env --env-file-if-exists=.env.local --import tsx server/index.ts",
    "start:api": "node --env-file-if-exists=.env --env-file-if-exists=.env.local --import tsx server/index.ts",
    "test": "npm run test:web && npm run test:server",
    "test:web": "vitest run",
    "test:server": "node --import tsx --test server/*.test.ts server/**/*.test.ts",
    "test:nemoclaw": "node --import tsx --test server/channels/nemoclawChannel.test.ts server/channels/nemoclawServer.e2e.test.ts",
    "typecheck": "tsc -b",
    "test:gradium:manual": "node --env-file-if-exists=.env --import tsx server/voice/gradiumConnectivity.manual.ts",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint ."
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.5",
    "express": "^5.2.1",
    "lucide-react": "^0.525.0",
    "openai": "^6.46.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-router-dom": "^7.6.0",
    "twilio": "^6.0.2",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/express": "^5.0.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^10.0.3",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "jsdom": "^29.1.1",
    "tsx": "^4.23.0",
    "typescript": "^5",
    "typescript-eslint": "^8.30.0",
    "vite": "^7.0.0",
    "vitest": "^4.1.10"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
